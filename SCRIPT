            SubTab.Btn.Font = Enum.Font.SourceSansBold
            SubTab.Btn.TextSize = 12
            SubTab.Btn.ZIndex = 8
            SubTab.Btn.Parent = Tab.SubTabContainer
            Instance.new("UICorner", SubTab.Btn).CornerRadius = UDim.new(0, 4)

            local function showSubTab()
                triggerSound()
                for _, st in pairs(Tab.SubTabs) do
                    st.Frame.Visible = false
                    st.Btn.TextColor3 = LogQuickLib.CurrentTheme.TextMuted
                    st.Btn.BackgroundColor3 = LogQuickLib.CurrentTheme.Element
                end
                Tab.Frame.Visible = false 
                SubTab.Frame.Visible = true
                SubTab.Btn.TextColor3 = LogQuickLib.CurrentTheme.Accent
                SubTab.Btn.BackgroundColor3 = LogQuickLib.CurrentTheme.Background
                Tab.ActiveSubTab = SubTab
            end

            SubTab.Btn.MouseButton1Click:Connect(showSubTab)
            table.insert(Tab.SubTabs, SubTab)

            -- 注入API生成组件到子页面
            LogQuickLib:InjectAPI(SubTab)
            return SubTab
        end

        -- 注入API生成组件到主Tab
        LogQuickLib:InjectAPI(Tab)
        return Tab
    end

    -- ==================== 内置设置面板 ====================
    local SettingsTab = Window:CreateTab("UI Settings", 6031289233)
    
