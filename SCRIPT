-- ==================== 组件 API 构造与注入 ====================
function LogQuickLib:InjectAPI(TabOrSubTab)
    local ParentFrame = TabOrSubTab.Frame
    local elementCount = 0

    -- 动态 Canvas 高度自适应
    local function adjustCanvasSize()
        local height = 0
        for _, child in pairs(ParentFrame:GetChildren()) do
            if child:IsA("Frame") or child:IsA("TextLabel") or child:IsA("ImageLabel") then
                height = height + child.Size.Y.Offset + 8
            end
        end
        ParentFrame.CanvasSize = UDim2.new(0, 0, 0, height + 30)
    end

    -- 1. 功能分区 (Section)
