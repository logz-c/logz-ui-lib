    textLabel.BackgroundTransparency = 1
    textLabel.TextColor3 = Color3.fromRGB(240, 240, 240)
    textLabel.Font = Enum.Font.Code
    textLabel.TextSize = 11
    textLabel.Text = "FPS: --\nPING: -- ms"
    textLabel.Parent = frame

    makeDraggable(frame, 0.05)
    self.HUDFrame = frame

    local lastUpdate = 0
    local fpsCount = 0
    RunService.RenderStepped:Connect(function()
        if not self.Config.FloatingHUD then 
            frame.Visible = false
            return 
        else
            frame.Visible = true
        end

        fpsCount = fpsCount + 1
        if tick() - lastUpdate >= 1 then
            local ping = "N/A"
            pcall(function()
                ping = math.floor(game:GetService("Stats").Network.ServerConnection:GetPing() * 1000)
            end)
            textLabel.Text = string.format("FPS: %d\nPING: %s ms", fpsCount, tostring(ping))
            fpsCount = 0
            lastUpdate = tick()
        end
    end)
end

