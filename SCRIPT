        label.Parent = pickerFrame

        local preview = Instance.new("Frame")
        preview.Size = UDim2.new(0, 30, 0, 20)
        preview.Position = UDim2.new(1, -40, 0, 5)
        preview.BackgroundColor3 = defaultColor
        preview.ZIndex = 10
        preview.Parent = pickerFrame
        Instance.new("UICorner", preview).CornerRadius = UDim.new(0, 4)

        local function updateColor()
            local col = Color3.fromHSV(h, s, v)
            preview.BackgroundColor3 = col
            callback(col)
        end

        local hSlider = Instance.new("Frame")
        hSlider.Size = UDim2.new(0.9, 0, 0, 20)
        hSlider.Position = UDim2.new(0.05, 0, 0.25, 10)
        hSlider.BackgroundTransparency = 1
        hSlider.ZIndex = 9
        hSlider.Parent = pickerFrame
        
        self:InjectAPI({Frame = hSlider})
        hSlider:CreateSlider("H (Hue)", 0, 1, h, function(val)
            h = val; updateColor()
        end)

        local sSlider = Instance.new("Frame")
        sSlider.Size = UDim2.new(0.9, 0, 0, 20)
        sSlider.Position = UDim2.new(0.05, 0, 0.45, 15)
        sSlider.BackgroundTransparency = 1
        sSlider.ZIndex = 9
        sSlider.Parent = pickerFrame
        self:InjectAPI({Frame = sSlider})
        sSlider:CreateSlider("S (Saturation)", 0, 1, s, function(val)
            s = val; updateColor()
        end)

        local vSlider = Instance.new("Frame")
        vSlider.Size = UDim2.new(0.9, 0, 0, 20)
        vSlider.Position = UDim2.new(0.05, 0, 0.65, 20)
        vSlider.BackgroundTransparency = 1
        vSlider.ZIndex = 9
        vSlider.Parent = pickerFrame
        self:InjectAPI({Frame = vSlider})
        vSlider:CreateSlider("V (Value)", 0, 1, v, function(val)
            v = val; updateColor()
        end)

        adjustCanvasSize()
    end

    -- 12. 搜索框 (SearchBar)
    function TabOrSubTab:CreateSearchBar(placeholder, callback)
        elementCount = elementCount + 1
        local sFrame = Instance.new("Frame")
        sFrame.Size = UDim2.new(0.95, 0, 0, 38)
        sFrame.BackgroundColor3 = LogQuickLib.CurrentTheme.Element
        sFrame.LayoutOrder = elementCount
        sFrame.ZIndex = 8
        sFrame.Parent = ParentFrame
        Instance.new("UICorner", sFrame).CornerRadius = UDim.new(0, 6)

        local box = Instance.new("TextBox")
        box.Size = UDim2.new(0.95, 0, 0.8, 0)
        box.Position = UDim2.new(0.025, 0, 0.1, 0)
        box.BackgroundTransparency = 1
        box.TextColor3 = LogQuickLib.CurrentTheme.Text
        box.PlaceholderText = placeholder or "Search features..."
        box.PlaceholderColor3 = LogQuickLib.CurrentTheme.TextMuted
        box.Font = Enum.Font.SourceSans
        box.TextSize = 14
        box.Text = ""
        box.ZIndex = 9
        box.Parent = sFrame

        box:GetPropertyChangedSignal("Text"):Connect(function()
            callback(box.Text)
        end)

        adjustCanvasSize()
    end

    -- 13. 图片渲染组件 (ImageDisplay)
    function TabOrSubTab:CreateImageDisplay(imageId, sizeY)
        elementCount = elementCount + 1
        local img = Instance.new("ImageLabel")
        img.Size = UDim2.new(0.95, 0, 0, sizeY or 100)
        img.BackgroundTransparency = 1
        img.Image = "rbxassetid://" .. tostring(imageId):gsub("rbxassetid://", "")
        img.ScaleType = Enum.ScaleType.Fit
        img.LayoutOrder = elementCount
        img.ZIndex = 8
        img.Parent = ParentFrame

        adjustCanvasSize()
    end
end

return LogQuickLib
