    mainFrame.BackgroundColor3 = self.CurrentTheme.Background
    mainFrame.BackgroundTransparency = self.Config.Transparency
    mainFrame.BorderSizePixel = 0
    mainFrame.ZIndex = 5
    mainFrame.Parent = MainScreenGui

    local mainCorner = Instance.new("UICorner")
    mainCorner.CornerRadius = UDim.new(0, 10)
    mainCorner.Parent = mainFrame

    -- 边框设置
    local stroke = applyStroke(mainFrame, self.CurrentTheme.Border, self.Config.BorderSize)

    -- 边框特效 (通过 Lerp 平滑计算，不会阻断主线程)
    local bTime = 0
    RunService.RenderStepped:Connect(function(dt)
