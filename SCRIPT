        label.Font = Enum.Font.SourceSansBold
        label.TextSize = 14
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.ZIndex = 9
        label.Parent = sFrame

        local valLabel = Instance.new("TextLabel")
        valLabel.Size = UDim2.new(0.3, 0, 0, 25)
        valLabel.Position = UDim2.new(0.7, -10, 0, 2)
        valLabel.BackgroundTransparency = 1
        valLabel.TextColor3 = LogQuickLib.CurrentTheme.TextMuted
        valLabel.Text = tostring(math.round(val * 100) / 100)
        valLabel.Font = Enum.Font.Code
        valLabel.TextSize = 13
        valLabel.TextXAlignment = Enum.TextXAlignment.Right
        valLabel.ZIndex = 9
        valLabel.Parent = sFrame

        local sliderBar = Instance.new("Frame")
        sliderBar.Size = UDim2.new(0.9, 0, 0, 6)
        sliderBar.Position = UDim2.new(0.05, 0, 0.7, 0)
        sliderBar.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
        sliderBar.ZIndex = 9
        sliderBar.Parent = sFrame
        Instance.new("UICorner", sliderBar).CornerRadius = UDim.new(1, 0)

        local sliderFill = Instance.new("Frame")
        local percent = (val - min) / (max - min)
        sliderFill.Size = UDim2.new(percent, 0, 1, 0)
        sliderFill.BackgroundColor3 = LogQuickLib.CurrentTheme.Accent
        sliderFill.ZIndex = 10
        sliderFill.Parent = sliderBar
        Instance.new("UICorner", sliderFill).CornerRadius = UDim.new(1, 0)

        local function move(input)
            local xOffset = math.clamp(input.Position.X - sliderBar.AbsolutePosition.X, 0, sliderBar.AbsoluteSize.X)
            local rawVal = min + (xOffset / sliderBar.AbsoluteSize.X) * (max - min)
            val = math.round(rawVal * 100) / 100
            valLabel.Text = tostring(val)
            sliderFill.Size = UDim2.new(xOffset / sliderBar.AbsoluteSize.X, 0, 1, 0)
            callback(val)
        end

        local active = false
        sliderBar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                active = true
                move(input)
            end
        end)

        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                active = false
            end
        end)

        UserInputService.InputChanged:Connect(function(input)
            if active and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                move(input)
            end
        end)

        adjustCanvasSize()
    end

