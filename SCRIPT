                end
            end
            
            Tab.Btn.TextColor3 = LogQuickLib.CurrentTheme.Accent
            Tab.Btn.BackgroundColor3 = LogQuickLib.CurrentTheme.Background

            if #Tab.SubTabs > 0 then
