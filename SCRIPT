    -- 移动端检测
    local isMobile = UserInputService.TouchEnabled
    local defaultScale = isMobile and 1.25 or 1.0
    self.Config.UI_Scale = defaultScale

    -- 主框架
    local mainFrame = Instance.new("Frame")
    -- 采用固定尺寸，用UIScale做动画，物理上防崩
    mainFrame.Size = UDim2.new(0, 650, 0, 420)
    
    if self.Config.Position then
        mainFrame.Position = UDim2.new(0, self.Config.Position.X, 0, self.Config.Position.Y)
    else
        mainFrame.Position = UDim2.new(0.5, -325, 0.4, -210)
